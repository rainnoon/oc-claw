---
import { languages, langLabels, type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
---

<nav>
  <a href={`/${lang}/`} class="logo">
    <img src="/app-icon.png" alt="OC-Claw" class="logo-icon" />
    <span class="logo-label">OC-Claw</span>
  </a>
  <div class="nav-right">
    <div class="lang-switcher">
      {languages.filter(l => l !== lang).map(l => (
        <a href={`/${l}/`} class="nav-link lang-switch">{langLabels[l]}</a>
      ))}
    </div>
    <a href="https://github.com/rainnoon/oc-claw" class="nav-link">GitHub</a>
  </div>
</nav>

<style>
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .lang-switch {
    font-size: 0.85rem;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .lang-switch:hover {
    opacity: 1;
  }
</style>
