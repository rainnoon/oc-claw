---
// Root page: redirect to /en/ or /zh/ based on browser language.
// Since Astro is static, we use a client-side redirect.
---

<html>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      const lang = navigator.language.toLowerCase().startsWith('zh') ? 'zh' : 'en';
      window.location.replace('/' + lang + '/');
    </script>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </head>
</html>
